<body class="light">
    <!-- Loading Indicator -->
    <div id="blazor-loading" style="
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        flex-direction: column;
        gap: 20px;
    ">
        <div style="
            width: 50px;
            height: 50px;
            border: 4px solid rgba(255, 255, 255, 0.2);
            border-top-color: #00d4ff;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        "></div>
        <p style="color: #ffffff; font-size: 16px; margin: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">Chargement...</p>
    </div>
    
    <style>
        @@keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
    
    <Routes />
    
    <!-- Blazor optimisé -->
    <script src="./js/blazor.js" defer></script>
    
    
    <!-- AOS - chargé uniquement si nécessaire -->
    <script>
        if (document.querySelector('[data-aos]')) {
            const script = document.createElement('script');
            script.src = './lib/aos/aos.js?v=2026-07-03';
            script.defer = true;
            script.onload = function() {
                if (typeof AOS !== 'undefined') {
                    AOS.init({
                        duration: 800,
                        once: true,
                        offset: 50,
                        disable: window.innerWidth < 768 ? true : false
                    });
                }
            };
            document.body.appendChild(script);
        }
    </script>
    <!--script src="./script.min.js?v=2026-07-03" defer async></script-->
    <script src="./script.js?v=2026-07-03" defer async></script>
    
    <script>
        if ('performance' in window) {
            const observer = new PerformanceObserver((list) => {
                for (const entry of list.getEntries()) {
                    if (entry.entryType === 'largest-contentful-paint') {
                        //console.log('⚡ LCP:', entry.startTime, 'ms');
                    }
                }
            });
            observer.observe({ entryTypes: ['largest-contentful-paint'] });
        }
    </script>
</body>

</html>

