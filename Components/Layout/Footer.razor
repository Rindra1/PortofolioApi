@inject IJSRuntime JS

<footer class="footer-custom">
  <div class="footer-container">
    <!-- Grille principale -->
    <div class="footer-grid">
      
      <!-- Colonne 1 - Logo & Description -->
      <div class="footer-col footer-col-brand">
        <a href="#" class="footer-brand">
          <!--<div class="footer-logo-icon">
            <i class="fas fa-code"></i>
          </div>-->
          <span class="footer-brand-name">
            Rindra Niaina
          </span>
        </a>
        <p class="footer-description">
          @Localizer.T("FooterDescription")
        </p>
        <!-- Réseaux sociaux -->
        <div class="footer-socials">
          <a href="https://github.com/Rindra1" class="footer-social-link" aria-label="Profil GitHub de Rindra"
             target="_blank"
             rel="noopener noreferrer">
            <i class="fab fa-github"></i>
          </a>
          <a href="https://www.linkedin.com/in/rindra-niaina-razafimandanona-1ab51b120" class="footer-social-link" 
             aria-label="Profil linkedin de Rindra"
             target="_blank"
             rel="noopener noreferrer">
            <i class="fab fa-linkedin-in"></i>
          </a>
          <a href="https://x.com/RindraNiaina3" class="footer-social-link"
             aria-label="Profil twitter de Rindra"
             target="_blank"
             rel="noopener noreferrer">
            <i class="fab fa-twitter"></i>
          </a>
        </div>
      </div>

      <!-- Colonne 2 - Liens rapides -->
      <div class="footer-col">
        <h3 class="footer-col-title">
          Navigation
        </h3>
        <ul class="footer-list">
          <li><a @onclick='() => ScrollToSection("accueil")' @onclick:preventDefault="true" class="footer-link" style="cursor: pointer;">@Localizer.T("Home")</a></li>
          <li><a @onclick='() => ScrollToSection("about")' @onclick:preventDefault="true" class="footer-link" style="cursor: pointer;">@Localizer.T("About")</a></li>
          <li><a @onclick='() => ScrollToSection("projets")' @onclick:preventDefault="true" class="footer-link" style="cursor: pointer;">@Localizer.T("Projects")</a></li>
          <li><a @onclick='() => ScrollToSection("experience")' @onclick:preventDefault="true" class="footer-link" style="cursor: pointer;">@Localizer.T("Experience")</a></li>
          <li><a @onclick='() => ScrollToSection("services")' @onclick:preventDefault="true" class="footer-link" style="cursor: pointer;">@Localizer.T("Services")</a></li>
          <li><a @onclick='() => ScrollToSection("contact")' @onclick:preventDefault="true" class="footer-link" style="cursor: pointer;">@Localizer.T("Contact")</a></li>
        </ul>
      </div>

      <!-- Colonne 3 - Services -->
      <div class="footer-col">
        <h3 class="footer-col-title">
          Services
        </h3>
        <ul class="footer-list">
          <li><a @onclick='() => ScrollToSection("services")' @onclick:preventDefault="true" class="footer-link" style="cursor: pointer;">@Localizer.T("Service.1.Title")</a></li>
          <li><a @onclick='() => ScrollToSection("services")' @onclick:preventDefault="true" class="footer-link" style="cursor: pointer;">@Localizer.T("Service.2.Title")</a></li>
          <li><a @onclick='() => ScrollToSection("services")' @onclick:preventDefault="true" class="footer-link" style="cursor: pointer;">@Localizer.T("Service.3.Title")</a></li>
          <li><a @onclick='() => ScrollToSection("services")' @onclick:preventDefault="true" class="footer-link" style="cursor: pointer;">@Localizer.T("Service.4.Title")</a></li>
        </ul>
      </div>

      <!-- Colonne 4 - Contact -->
      <div class="footer-col">
        <h3 class="footer-col-title">
          Contact
        </h3>
        <ul class="footer-contact-list">
          <li class="footer-contact-item">
            <i class="fas fa-envelope footer-contact-icon"></i>
            <span>rindraniaina.manda@gmail.com</span>
          </li>
          <li class="footer-contact-item">
            <i class="fas fa-phone footer-contact-icon"></i>
            <span>+261 32 52 781 38</span>
          </li>
          <li class="footer-contact-item">
            <i class="fas fa-map-marker-alt footer-contact-icon"></i>
            <span>Antananarivo, Madagascar</span>
          </li>
        </ul>
        <!-- Bouton contact -->
        <a @onclick='() => ScrollToSection("contact")' @onclick:preventDefault="true" class="footer-contact-btn" style="cursor: pointer;">
          <i class="fas fa-paper-plane"></i>
          @Localizer.T("ContactMe")
        </a>
      </div>
    </div>

    <!-- Séparateur -->
    <div class="footer-divider">
      <div class="footer-bottom">
        <p class="footer-copy">
          &copy; @DateTime.Now.Year Rindra Niaina. @Localizer?.T("AllRightsReserved")
        </p>
        <!--<div class="footer-legal">
          <a href="#" class="footer-legal-link">Politique de confidentialité</a>
          <a href="#" class="footer-legal-link">Mentions légales</a>
          <a href="#" class="footer-legal-link">Cookies</a>
        </div>-->
      </div>
    </div>
  </div>
</footer>

@code{
  [Parameter]
  public LocalizationService Localizer {get;set;}
  private async Task ScrollToSection(string sectionId)
  {
    await JS.InvokeVoidAsync("siteInterop.scrollToSection", sectionId);
  }
}