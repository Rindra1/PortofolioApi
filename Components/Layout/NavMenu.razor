private bool _initialized;

protected override async Task OnAfterRenderAsync(bool firstRender)
{
    if (firstRender && !_initialized)
    {
      _initialized = true;
      try { await Localizer.InitializeAsync(); } catch { }
      await JS.InvokeVoidAsync("siteInterop.initAll");
    }
}

private async Task ChangeLangAsync(string lang)
{
  await Localizer.SetLanguageAsync(lang);
  StateHasChanged();
}

private async Task OnLangSelectChange(ChangeEventArgs e)
{
    var val = e?.Value?.ToString();
    if (!string.IsNullOrEmpty(val)) await ChangeLangAsync(val);
}

private Task SetFr() => ChangeLangAsync("fr");
private Task SetEn() => ChangeLangAsync("en");

private bool _langOpen = false;
private void ToggleLangDropdown() => _langOpen = !_langOpen;
private async Task SelectLangAndClose(string lang)
{
  _langOpen = false;
  await ChangeLangAsync(lang);
}

private async Task ToggleLanguage()
{
    await SelectLangAndClose(
        Localizer.CurrentLanguage == "fr" ? "en" : "fr");
}


