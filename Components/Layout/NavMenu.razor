
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject UserState UserState
@inject TokenServices TokenService
@inject PortofolioApi.Services.LocalizationService Localizer
@rendermode InteractiveServer 

<header>
    <div class="container nav-flex">
        <div class="logo"><span><img src="/images/rindra_logo.png" loading="lazy" alt="Rindra logo"/></span></div>
        <div class="controls">
            <button class="lang-toggle" id="langToggle"  @onclick="ToggleLanguage"><i class="fas fa-globe"></i></button>
            <button class="theme-toggle" id="themeToggle"><i class="fas fa-moon"></i></button>
            <button class="mobile-menu-btn" id="mobileMenuBtn"><i class="fas fa-bars"></i></button>
        </div>
       
        <div class="nav-links">
            <a href="#accueil">@Localizer.T("Home")</a>
            <a href="#about">@Localizer.T("About")</a>
            <a href="#projets">@Localizer.T("Projects")</a>
            <a href="#experience">@Localizer.T("Experience")</a>
            <a href="#services">@Localizer.T("Services")</a>
            <a href="#contact">@Localizer.T("Contact")</a>
            <a href="#" class="btn-cv" id="downloadCVBtn"><i class="fas fa-download"></i> @Localizer.T("DownloadCV")</a>
        </div>
    </div>
    <div class="mobile-nav" id="mobileNav">
        <a href="#accueil">@Localizer.T("Home")</a>
        <a href="#about">@Localizer.T("About")</a>
        <a href="#projets">@Localizer.T("Projects")</a>
        <a href="#experience">@Localizer.T("Experience")</a>
        <a href="#services">@Localizer.T("Services")</a>
        <a href="#contact">@Localizer.T("Contact")</a>
        <a href="#" class="btn-cv-mobile" id="downloadCVBtnMobile"><i class="fas fa-download"></i> @Localizer.T("DownloadCV")</a>
    </div>
</header>



