<!-- Chatbot flottant -->
<div class="chatbot-container">
  <div class="chat-toggle" id="chat-toggle" role="button" tabindex="0" aria-controls="chat-body" aria-expanded="false">
    <img src="images/chatbot1.png" alt="Chat" class="chat-icon" />
  </div>
  <div class="chat-body" id="chat-body" aria-hidden="true">
    <div class="chat-messages" id="chat-messages">
      @if (ChatResponses != null && ChatResponses.Any())
      {
        <div class="chat-message bot">
          <span>@Localizer.T("ChatGreeting")</span>
        </div>
        foreach (var msg in ChatResponses)
        {
          <div class="chat-message user">
            <span>@msg.UserMessage</span>
          </div>
          <div class="chat-message bot">
            <span>@msg.BotResponse</span>
          </div>
        }
      }
      else
      {
        <div class="chat-message bot">
          <span>@Localizer.T("ChatGreeting")</span>
        </div>
      }
    </div>
    <div class="chat-input">
        <input autocomplete="off" type="text" placeholder='@Localizer.T("ChatPlaceholder")' id="chat-input-field"
          @bind="UserMessage" aria-label="Message" />
        <button type="button" id="chat-send-btn" @onclick="SendMessage" aria-label='@Localizer.T("Send")' title='@Localizer.T("Send")'>➤</button>
    </div>
  </div>
</div>

}

@code {
  private string message = string.Empty;
  private MailDTO emailRequest = new MailDTO();
  private HttpClient http;
  private UtilisateurDTO portfolio = new UtilisateurDTO();
  private string UserMessage { get; set; } = "";
  private List<ChatEntry> ChatResponses { get; set; } = new();
  private bool _initialized;

  protected override void OnInitialized()
  {
      // subscribe to language changes
      Localizer.OnChange += OnLangChanged;
  }

  private void OnLangChanged()
  {
      InvokeAsync(async () =>
      {
        try
        {
          if (portfolio != null)
          {
            if (Localizer.CurrentLanguage != "fr")
            {
              await TranslatePortfolioAsync(portfolio, Localizer.CurrentLanguage);
            }
            else
            {
              // reload original French content from API
              try
              {
                var url = $"http://localhost:5000/api/portfolio";
                var original = await Http.GetFromJsonAsync<UtilisateurDTO>(url);
                if (original != null) portfolio = original;
              }
              catch { }
            }
          }
        }
        catch { }
        StateHasChanged();
      });
  }

  public void Dispose()
  {
      Localizer.OnChange -= OnLangChanged;
  }

protected override async Task OnAfterRenderAsync(bool firstRender)
{
    if (firstRender && !_initialized)
    {
        _initialized = true;
        //await JS.InvokeVoidAsync("siteInterop.initAll");
        //await JS.InvokeAsync<string>("themeManager.applyTheme");
        try
    {
      string url = $"http://localhost:5000/api/portfolio";
      // ensure localizer initialized
      try { await Localizer.InitializeAsync(); } catch { }

      portfolio = await Http.GetFromJsonAsync<UtilisateurDTO>(url)??null;
      Console.WriteLine("Portfolio:");
      Console.WriteLine(System.Text.Json.JsonSerializer.Serialize(portfolio));
      //Console.WriteLine(System.Text.Json.JsonSerializer.Serialize(portfolio));
        StateHasChanged();

        // Traduire le contenu dynamique si la langue est autre que FR
        if (Localizer.CurrentLanguage != "fr" && portfolio != null)
        {
          try { await TranslatePortfolioAsync(portfolio, Localizer.CurrentLanguage); StateHasChanged(); } catch { }
        }
      // Appeler l'initialisation JavaScript déjà incluse via App.razor
      await JS.InvokeVoidAsync("siteInterop.initAll");
      await JS.InvokeVoidAsync("siteInterop.hideLoader");
      
    }catch(Exception ex)
    {
        message = $"Erreur: {ex.Message} {ex.StackTrace}";
        Console.WriteLine(message);
    }
    }
}


