  {
    if (firstRender)
    {
      await JS.InvokeVoidAsync("siteInterop.initAll");
      await JS.InvokeAsync<string>("themeManager.applyTheme");
    }
  }*/
  
  private async Task SendMessage()
  {
    if (string.IsNullOrWhiteSpace(UserMessage))
      return;

    // Sauvegarder le message utilisateur
    var userMsg = UserMessage;

    try
    {
      var response = await Http.PostAsJsonAsync("api/chat", new { message = userMsg });

      if (response.IsSuccessStatusCode)
      {
        var chatResponse = await response.Content.ReadFromJsonAsync<ChatResponse>();
                
        ChatResponses.Add(new ChatEntry
        {
          UserMessage = userMsg,
          BotResponse = ""//chatResponse?.Message ?? "Aucune réponse"
        });
        var botMessage = chatResponse?.Message ?? "Aucune réponse";
         // Afficher le message caractère par caractère
            await TypeBotResponse(botMessage);
      }
      else
      {
        ChatResponses.Add(new ChatEntry
        {
          UserMessage = userMsg,
          BotResponse = $"Erreur : {response.StatusCode}"
        });
      }
    }
    catch (Exception ex)
    {
      ChatResponses.Add(new ChatEntry
      {
        UserMessage = userMsg,
        BotResponse = $"Exception : {ex.Message}"
      });
    }

          // Ne pas réinitialiser la réponse complète, seulement le champ input
          UserMessage = "";

          // Faire défiler le chat vers le bas si la fonction JS existe
          try { await JS.InvokeVoidAsync("eval", "window.scrollChatToBottom()"); } catch { }
  }

  private async Task TypeBotResponse(string botMessage)
{
    var typedResponse = "";
    foreach (var c in botMessage)
    {
        typedResponse += c;

        // Mettre à jour la dernière entrée du chat
        ChatResponses.Last().BotResponse = typedResponse;

        // Rafraîchir l’UI
        StateHasChanged();

        // Pause entre chaque caractère (ajuste la vitesse)
        await Task.Delay(30); 
    }
}


  private class ChatEntry
  {
    public string UserMessage { get; set; } = "";
    public string BotResponse { get; set; } = "";
  }

    private async Task TranslatePortfolioAsync(UtilisateurDTO p, string target)
    {
      Console.WriteLine($"Translating portfolio to '{target}'");
      if (p == null) return;

      // Use resource-based translations for the main profile strings
      try
      {
        // Localizer.CurrentLanguage should already equal target when called
        p.APropos = Localizer.T("APropos");
        p.resume = Localizer.T("Resumer");
      }
      catch (Exception ex)
      {
        Console.WriteLine("TranslatePortfolioAsync resource lookup failed: " + ex.Message);
      }

      // Helper to normalize text into a resource-key friendly string
      string NormalizeKey(string s)
      {
        if (string.IsNullOrWhiteSpace(s)) return string.Empty;
        var t = s.Trim().ToLowerInvariant();
        var sb = new System.Text.StringBuilder();
        foreach (var ch in t)
        {
          if (char.IsLetterOrDigit(ch)) sb.Append(ch);
          else sb.Append('_');
        }
        return sb.ToString();
      }

      // Translate competences
      if (p.Competences != null)
      {
        foreach (var c in p.Competences)
        {
          try
          {
            var original = c.Nom ?? string.Empty;
            var keyById = $"Competence.{c.IdCompetence}.Nom";
            var k1 = Localizer.T(keyById);
            if (k1 != keyById) { c.Nom = k1; continue; }

            var keyByName = $"Competence.{NormalizeKey(original)}";
            var k2 = Localizer.T(keyByName);
            if (k2 != keyByName) { c.Nom = k2; continue; }

            // leave original if no resource found
            c.Nom = original;
          }
          catch { }
        }
      }

      // Translate projects
      if (p.Projets != null)
      {
        foreach (var proj in p.Projets)
        {
          try
          {
            var idPart = proj.IdProjet?.ToString() ?? "0";
            var titleKey = $"Projet.{idPart}.Titre";
            var summaryKey = $"Projet.{idPart}.Resumer";
            var detailKey = $"Projet.{idPart}.Detail";

            var tTitle = Localizer.T(titleKey);
            if (tTitle != titleKey) proj.TitreProjet = tTitle;

            var tSummary = Localizer.T(summaryKey);
            if (tSummary != summaryKey) proj.ResumerProjet = tSummary;

            var tDetail = Localizer.T(detailKey);
            if (tDetail != detailKey) proj.DetailProjet = tDetail;
          }
          catch { }
        }
      }

      // Translate experiences
      if (p.Experiences != null)
      {
        foreach (var exp in p.Experiences)
        {
          try
          {
            var idPart = exp.IdExperience.ToString();
            var titreKey = $"Experience.{idPart}.Titre";
            var detailKey = $"Experience.{idPart}.Detail";

            var tt = Localizer.T(titreKey);
            if (tt != titreKey) exp.TitreExperience = tt;

            var td = Localizer.T(detailKey);
            if (td != detailKey) exp.DetailExperience = td;
          }
          catch { }
        }
      }

      await Task.CompletedTask;
    }

  private async Task Envoyer()
{
    if (emailRequest == null)
        return;

    try
    {
        // URL propre, pas de "?" ajouté
        var response = await Http.PostAsJsonAsync("api/mail/sendgrid", emailRequest);

        MailResponseDTO result = null;

        try
        {
            // Essayer de lire la réponse JSON
            result = await response.Content.ReadFromJsonAsync<MailResponseDTO>();
        }
        catch
        {
            // Si JSON invalide, lire le texte brut
            var text = await response.Content.ReadAsStringAsync();
            result = new MailResponseDTO
            {
                Message = string.IsNullOrWhiteSpace(text) ? "Erreur inconnue" : text
            };
        }

        if (response.IsSuccessStatusCode)
        {
            Console.WriteLine(result?.Message);
        }
        else
        {
            Console.WriteLine("Erreur : " + result?.Message);
            if (!string.IsNullOrEmpty(result?.Error))
            {
                Console.WriteLine("Détails : " + result.Error);
            }
        }
    }
    catch (Exception ex)
    {
        Console.WriteLine("Exception : " + ex.Message);
    }
}
}
