@page "/"

@rendermode InteractiveServer

@inject HttpClient Http

@inject IJSRuntime JS

@inject PortofolioApi.Services.LocalizationService Localizer

@using Microsoft.EntityFrameworkCore.Metadata.Conventions

@using PortofolioApi.Domain.DTOs

@using Microsoft.AspNetCore.Components

<main>
    <section id="accueil" class="hero-section">
        <div class="container hero">
            <div class="hero-content" data-aos="fade-right">
                <div class="dispo-badge"><span class="green-circle"></span> @Localizer.T("Available")</div>
                <div class="hero-name">@portfolio.Nom <span>@portfolio.Prenom</span></div>
                <div class="hero-title">@portfolio.Titre</div>
                <p class="hero-description">@portfolio.resume </p>
                <div class="hero-buttons">
                    <a href="#projets" class="btn-primary"><i class="fas fa-arrow-right"></i> @Localizer.T("ViewProjects")</a>
                    <a href="#contact" class="btn-outline"><i class="fas fa-envelope"></i> @Localizer.T("ContactMe")</a>
                </div>
                <div class="hero-stats">
                    <div class="stat-card"><div class="stat-number">5+</div><div class="stat-label">@Localizer.T("YearsOfExperience")</div></div>
                    <div class="stat-card"><div class="stat-number">5+</div><div class="stat-label">@Localizer.T("CompletedProjects")</div></div>
                    <div class="stat-card"><div class="stat-number">10+</div><div class="stat-label">Technologies</div></div>
                    <!--<div class="stat-card"><div class="stat-number">100%</div><div class="stat-label">Satisfaction client</div></div>-->
                </div>
                <div class="hero-stack-section">
                    <div class="hero-stack-title"><i class="fas fa-layer-group"></i> @Localizer.T("MasteredStack")</div>
                    <div class="stack-items">
                        @if(!string.IsNullOrEmpty(portfolio.StackMaitrise))
                        {
                            @foreach(var tech in portfolio.StackMaitrise.Split(','))
                            {
                                <span class="stack-item">@tech</span>    
                            }
                        }
                    </div>
                </div>
            </div>
            <div class="hero-image-container" data-aos="fade-left">
                <div class="profile-circle">
                    <img src="images/@portfolio.UserImage" alt="@portfolio.Nom @portfolio.Prenom" loading="lazy"/>
                </div>
            </div>
        </div>
    </section>

    <!-- À PROPOS -->

    <section id="about">
        <div class="container">
            <h2 class="section-title">@Localizer.T("About")</h2>
            <div class="about-wrapper">
                <div class="about-text" data-aos="fade-up">
                    <p>@portfolio.APropos</p>
                </div>
                <div class="skills-box" data-aos="fade-up" data-aos-delay="150">
                    <h3><i class="fas fa-code"></i> @Localizer.T("TechnicalStack")</h3>
                    <div style="display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top:1rem;">
                        @if(!string.IsNullOrEmpty(portfolio.StackTechnique))
                        {
                            @foreach(var tech in portfolio.StackTechnique.Split(','))
                            {
                                <span class="tech-badge">@tech</span>    
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- PROJETS -->

    <section id="projets">
        <div class="container">
            <h2 class="section-title">@Localizer.T("CompletedProjects")</h2>
            <div class="projets-grid">
                @foreach(var proj in portfolio.Projets)
                {
                    projet++;
                    <div class="card" data-aos="zoom-in">
                        <img src="/images/@(proj.ImageProjet)" alt="@proj.TitreProjet" loading="lazy" class="project-img">
                        <div class="card-content">
                            <h3>@proj.TitreProjet</h3>
                            <p>@proj.ResumerProjet</p>
                        </div>
                        <div class="card-actions">
                            <button class="btn-details" onclick="openModal('@projet')">
                                <i class="fas fa-info-circle"></i> Détails
                            </button>
                            @if(!string.IsNullOrEmpty(proj.Lien))
                            {
                                <a href="@proj.Lien" class="btn-github" target="_blank" rel="noopener noreferrer">
                                    <i class="fab fa-github"></i> GitHub
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- MODALES PROJETS AVEC CARROUSEL -->

    @foreach(var proj in portfolio.Projets)
    {
        projetdetail++;
        <div id="modal-@projetdetail" class="modal">
            <div class="modal-content">
                <span class="modal-close" onclick="closeModal('@projetdetail')">&times;</span>
                <h2 class="modal-title">@proj.TitreProjet</h2>
                <div class="modal-gallery" id="gallery@projetdetail">
                    <img id="mainImage@projetdetail" class="main-image" src="/images/@(proj.ImageProjet)" alt="@proj.TitreProjet">
                    <div class="thumbnail-container">
                        @if(!string.IsNullOrEmpty(proj.ImageProjet))
                        {
                            <img class="thumbnail" src="/images/@(proj.ImageProjet)" alt="@proj.TitreProjet" data-img="/images/@(proj.ImageProjet)">
                        }

                        @if(!string.IsNullOrEmpty(proj.ImageProjet1))
                        {
                            <img class="thumbnail" src="/images/@(proj.ImageProjet1)" alt="@proj.TitreProjet" data-img="/images/@(proj.ImageProjet1)">
                        }

                        @if(!string.IsNullOrEmpty(proj.ImageProjet2))
                        {
                            <img class="thumbnail" src="/images/@(proj.ImageProjet2)" alt="@proj.TitreProjet" data-img="/images/@(proj.ImageProjet2)">
                        }
                    </div>
                </div>
                <p class="modal-description">
                    @if(!string.IsNullOrEmpty(proj.DetailProjet))
                    {
                        <strong>@Localizer.T("FullDescription") :</strong><br/>@(new MarkupString(proj.DetailProjet.Replace("\\n", "<br/>"))) 
                    }
                </p>
                <p class="modal-description">
                    @if(!string.IsNullOrEmpty(proj.Fonctionnalite))
                    {
                        <strong>Fonctionnalités :</strong><br/>@(new MarkupString(proj.Fonctionnalite.Replace("\\n", "<br/>")))
                    }
                </p>

                <div class="modal-techs">
                    @if(!string.IsNullOrEmpty(proj.Stack))
                    {
                        foreach(var tech in proj.Stack.Split(','))
                        {
                            <span class="tech-badge">@tech.Trim()</span>
                        }
                    }
                </div>

                <div class="modal-links">
                    @if(!string.IsNullOrEmpty(proj.Lien))
                    {
                        <a href="@proj.Lien" class="btn-primary" style="padding:0.5rem 1.2rem;" target="_blank" rel="noopener noreferrer">
                            <i class="fab fa-github"></i> Voir GitHub
                        </a>
                    }                                
                </div>
            </div>
        </div>
    }

    <section id="experience">
        <div class="container">
            <h2 class="section-title">@Localizer.T("ProfessionalExperience")</h2>
            <div class="experience-container">
                @foreach(var exp in portfolio.Experiences.OrderByDescending(e => e.DateDebut))
                {
                    <div class="exp-item" data-aos="fade-right" data-aos-delay="200">
                        <div style="display:flex; justify-content:space-between;">
                            <h3>@Localizer.T(exp.TitreExperience)</h3>
                            <span style="color:#4f46e5;">@exp.DateDebut.Year - @(exp.DateFin.HasValue ? exp.DateFin.Value.ToString("yyyy") : Localizer.T("Present"))</span>
                        </div>
                        <p>@(new MarkupString(exp.DetailExperience.Replace("\\n", "<br/>")))</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <section id="services">
        <div class="container">
            <h2 class="section-title">@Localizer.T("MyServices")</h2>
            <div class="services-grid">
                <div class="service-card" data-aos="flip-left"><i class="fas fa-laptop-code"></i><h3>Applications WinForms</h3><p>Desktop robuste VB.NET/C#</p></div>
                <div class="service-card" data-aos="flip-left" data-aos-delay="100"><i class="fas fa-globe"></i><h3>Applications Blazor</h3><p>Web modernes et réactives</p></div>
                <div class="service-card" data-aos="flip-left" data-aos-delay="200"><i class="fas fa-cloud-upload-alt"></i><h3>API ASP.NET Core</h3><p>APIs RESTful sécurisées JWT</p></div>
                <!--<div class="service-card" data-aos="flip-left" data-aos-delay="300"><i class="fas fa-database"></i><h3>Optimisation SQL Server</h3><p>Schémas, requêtes, indexation</p></div>-->
            </div>
        </div>
    </section>

    <section id="contact">
        <div class="container">
            <h2 class="section-title">Contact</h2>
            <div class="contact-wrapper">
                <div class="contact-info-card" data-aos="fade-right">
                    <h3>📬 @Localizer.T("LetsStayInTouch")</h3>
                    <p>@Localizer.T("AvailableFor")</p>
                    <div class="contact-details">
                        <div class="contact-item"><i class="fas fa-phone"></i><span><a href="tel:+261341234567" target="_blank" rel="noopener noreferrer">+261 32 52 781 38</a></span></div>
                        <div class="contact-item"><i class="fas fa-envelope"></i><span><a href="mailto:rindraniaina.manda@gmail.com" target="_blank" rel="noopener noreferrer">rindraniaina.manda@gmail.com</a></span></div>
                        <div class="contact-item"><i class="fab fa-github"></i><span><a href="https://github.com/Rindra1" target="_blank" rel="noopener noreferrer">https://github.com/Rindra1</a></span></div>
                        <div class="contact-item"><i class="fab fa-linkedin"></i><span><a href="https://www.linkedin.com/in/rindra-niaina-razafimandanona-1ab51b120" target="_blank" rel="noopener noreferrer">https://www.linkedin.com/in/rindra-niaina-razafimandanona-1ab51b120</a></span></div>
                    </div>
                    <div class="social-links">
                        <a href="https://github.com/Rindra1" class="social-link" target="_blank" rel="noopener noreferrer"><i class="fab fa-github"></i></a>
                        <a href="https://www.linkedin.com/in/rindra-niaina-razafimandanona-1ab51b120" target="_blank" rel="noopener noreferrer" class="social-link"><i class="fab fa-linkedin-in"></i></a>
                        <a href="https://x.com/RindraNiaina3" class="social-link" target="_blank" rel="noopener noreferrer"><i class="fab fa-twitter"></i></a>
                        <a href="https://wa.me/261325278138" class="social-link" target="_blank" rel="noopener noreferrer"><i class="fab fa-whatsapp"></i></a>
                    </div>
                </div>

                <div class="contact-form-card" data-aos="fade-left">
                    <h3>@Localizer.T("SendMeMessage")</h3>
                    <form id="contactForm" @onsubmit="Envoyer" novalidate>
                        <div class="form-group"><input type="text" @bind="emailRequest.Name" id="userName" placeholder="Votre nom" required></div>
                        <div class="form-group"><input type="email" @bind="emailRequest.To" id="userEmail" placeholder="Votre email" required></div>
                        <div class="form-group"><textarea @bind="emailRequest.Body" id="userMessage" rows="4" placeholder="Votre message..." required></textarea></div>
                        <button type="submit" class="btn-submit"><i class="fas fa-paper-plane"></i> @Localizer.T("SendMessage")</button>
                        <div id="formStatus" class="form-message"></div>
                    </form>
                </div>
            </div>
        </div>
    </section>
</main>

<!-- CHATBOT FLOATING WINDOW -->

<div class="chatbot-float">
    <div class="chatbot-toggle" id="chatbotToggle"><i class="fas fa-comment-dots"></i><div class="online-dot"></div></div>
    <div class="chat-window" id="chatWindow">
        <div class="chat-header">
            <div class="chat-header-left">
                <div class="chat-avatar">RN</div>
                <div>
                    <strong>Assistant RN</strong>
                    <div style="font-size:0.7rem;"><i class="fas fa-circle" style="font-size:0.5rem; color:#4ade80;"></i> @Localizer.T("Online")</div>
                </div>
            </div>
            <button class="close-chat" id="closeChat"><i class="fas fa-times"></i></button>
        </div>
        <div class="chat-messages" id="chatMessagesFloat">
            @foreach(var entry in ChatResponses)
            {
                @if(!string.IsNullOrWhiteSpace(entry.UserMessage))
                {
                    <div class="message-user">
                        <div class="user-bubble">@entry.UserMessage</div>
                    </div>
                }
                <div class="message-bot">
                    <div class="bot-avatar">🤖</div>
                    <div class="bot-bubble">@entry.BotResponse</div>
                </div>
            }

            @if(string.IsNullOrWhiteSpace(ChatResponses.LastOrDefault()?.BotResponse) && ChatResponses.Count > 0)
            {
                <div class="typing-indicator">
                    <span></span><span></span><span></span>
                </div>
            }
        </div>
        <div class="chat-input-area">
            <input type="text" id="chatInputFloat" @bind="UserMessage" @bind:event="oninput" placeholder="@Localizer.T("YourQuestion")" @onkeydown="OnChatKeyPress" />
            <button id="sendChatFloat" @onclick="SendMessage"><i class="fas fa-paper-plane"></i></button>
        </div>
        <div class="suggestions-chat">
            <span class="suggestion-chip" @onclick='@(() => SendSuggestion("Quels sont ses projets .NET?"))'>📁 Projets .NET</span>
            <span class="suggestion-chip" @onclick='@(() => SendSuggestion("Quelle est sa stack technique?"))'>⚙️ Stack technique</span>
            <span class="suggestion-chip" @onclick='@(() => SendSuggestion("Est-il disponible pour freelance?"))'>💼 Disponibilité</span>
        </div>
    </div>
</div>
<footer class="footer">
    <p>&copy; @DateTime.Now.Year Rindra Niaina. @Localizer.T("AllRightsReserved")</p>
</footer>

@code {
    private string message = string.Empty;
    private MailDTO emailRequest = new MailDTO();
    private UtilisateurDTO portfolio = new UtilisateurDTO();
    private string UserMessage { get; set; } = "";
    private List<ChatEntry> ChatResponses { get; set; } = new();
    private bool _initialized;
    private int projet = 0;
    private int projetdetail = 0;
    // Chatbot API endpoint
    private string ChatApiEndpoint => "api/chat";
    protected override void OnInitialized()
    {
        Localizer.OnChange += OnLangChanged;
        // Add welcome message if chat is empty
        if (ChatResponses.Count == 0)
        {
            ChatResponses.Add(new ChatEntry
            {
                UserMessage = "",
                BotResponse = Localizer.T("MessageChat")
            });
        }
    }

    private void OnLangChanged()
    {
        InvokeAsync(async () =>
        {
            try
            {
                if (portfolio != null)
                {
                    if (Localizer.CurrentLanguage != "fr")
                    {
                        await TranslatePortfolioAsync(portfolio, Localizer.CurrentLanguage);
                    }
                    else
                    {
                        try
                        {
                            var url = $"api/portfolio";
                            var original = await Http.GetFromJsonAsync<UtilisateurDTO>(url);
                            if (original != null) portfolio = original;
                        }catch { }
                    }
                }
                // Update welcome message when language changes
                if (ChatResponses.Count > 0 && string.IsNullOrEmpty(ChatResponses[0].UserMessage))
                {
                    ChatResponses[0].BotResponse = Localizer.T("MessageChat");
                }
            }catch { }
            StateHasChanged();
        });
    }

    public void Dispose() => Localizer.OnChange -= OnLangChanged;
    

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            await JS.InvokeVoidAsync("siteInterop.initAll");
            try
            {
                string url = $"api/portfolio";
                try { await Localizer.InitializeAsync(); } catch { }
                portfolio = await Http.GetFromJsonAsync<UtilisateurDTO>(url) ?? new UtilisateurDTO();
                StateHasChanged();
                if (Localizer.CurrentLanguage != "fr" && portfolio != null)
                {
                    try { await TranslatePortfolioAsync(portfolio, Localizer.CurrentLanguage); StateHasChanged(); } catch { }
                }
                await JS.InvokeVoidAsync("siteInterop.initAll");
            }
            catch (Exception ex)
            {
                message = $"Erreur: {ex.Message} {ex.StackTrace}";
            }
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(UserMessage)) return;
        var userMsg = UserMessage;
        UserMessage = ""; // Clear input immediately
        // Add user message to chat
        ChatResponses.Add(new ChatEntry
        {
            UserMessage = userMsg,
            BotResponse = ""
        });
        StateHasChanged();
        try
        {
            var response = await Http.PostAsJsonAsync(ChatApiEndpoint, new { message = userMsg });
            if (response.IsSuccessStatusCode)
            {
                var chatResponse = await response.Content.ReadFromJsonAsync<ChatResponseDTO>();
                var botMessage = chatResponse?.Message ?? "Aucune réponse";
                await TypeBotResponse(botMessage);
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                ChatResponses.Last().BotResponse = $"Erreur : {errorMsg}";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            ChatResponses.Last().BotResponse = $"Exception : {ex.Message}";
            StateHasChanged();
        }
        await ScrollChatToBottom();
    }

    private async Task SendSuggestion(string suggestion)
    {
        UserMessage = suggestion;
        await SendMessage();
    }

    private void OnChatKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            SendMessage();
        }
    }

    private async Task TypeBotResponse(string botMessage)
    {
        var typedResponse = "";
        var lastEntry = ChatResponses.Last();
        foreach (var c in botMessage)
        {
            typedResponse += c;
            lastEntry.BotResponse = typedResponse;
            StateHasChanged();
            await Task.Delay(20);
        }
        await ScrollChatToBottom();
    }

    private async Task ScrollChatToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", @"
                var chatContainer = document.querySelector('#chatMessagesFloat');
                if(chatContainer) chatContainer.scrollTop = chatContainer.scrollHeight;
            ");
        }catch { }
    }

    private class ChatEntry
    {
        public string UserMessage { get; set; } = "";
        public string BotResponse { get; set; } = "";
    }

    private class ChatResponseDTO
    {
        public string Message { get; set; } = "";
    }

    private async Task TranslatePortfolioAsync(UtilisateurDTO p, string target)
    {
        if (p == null) return;
        try
        {
            p.APropos = Localizer.T("APropos");
            p.resume = Localizer.T("Resumer");
            p.Titre = Localizer.T("Title");
        }catch (Exception ex){}

        // Translate projects
        if (p.Projets != null)
        {
            foreach (var proj in p.Projets)
            {
                try
                {
                    var idPart = proj.IdProjet?.ToString() ?? "0";
                    var titleKey = $"Projet.{idPart}.Titre";
                    var summaryKey = $"Projet.{idPart}.Resumer";
                    var detailKey = $"Projet.{idPart}.Detail";
                    var fonctionnaliteKey = $"Projet.{idPart}.Fonctionnalite";
                    
                    var tTitle = Localizer.T(titleKey);
                    if (tTitle != titleKey) proj.TitreProjet = tTitle;

                    var tSummary = Localizer.T(summaryKey);
                    if (tSummary != summaryKey) proj.ResumerProjet = tSummary;

                    var tDetail = Localizer.T(detailKey);
                    if (tDetail != detailKey) proj.DetailProjet = tDetail;

                    var tFonctionnalite = Localizer.T(fonctionnaliteKey);
                    if (tFonctionnalite != fonctionnaliteKey) proj.Fonctionnalite = tFonctionnalite;

                }catch { }
            }
        }
        // Translate experiences
        if (p.Experiences != null)
        {
            foreach (var exp in p.Experiences)
            {
                try
                {
                    var idPart = exp.IdExperience.ToString();
                    var titreKey = $"Experience.{idPart}.Titre";
                    var detailKey = $"Experience.{idPart}.Detail";

                    var tt = Localizer.T(titreKey);
                    if (tt != titreKey) exp.TitreExperience = tt;

                    var td = Localizer.T(detailKey);
                    if (td != detailKey) exp.DetailExperience = td;
                }catch { }
            }
        }
        await Task.CompletedTask;
    }

    private async Task Envoyer()
    {
        if (emailRequest == null || string.IsNullOrWhiteSpace(emailRequest.Name) || string.IsNullOrWhiteSpace(emailRequest.To) || string.IsNullOrWhiteSpace(emailRequest.Body))
        {
            //await JS.InvokeVoidAsync("alert", "Veuillez remplir tous les champs");
            return;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("api/mail/sendgrid", emailRequest);
            MailResponseDTO? result = null;
            try
            {
                result = await response.Content.ReadFromJsonAsync<MailResponseDTO>();
            }
            catch
            {
                var text = await response.Content.ReadAsStringAsync();
                result = new MailResponseDTO
                {
                    Message = string.IsNullOrWhiteSpace(text) ? "Erreur inconnue" : text
                };
            }

            if (response.IsSuccessStatusCode)
            {
                //await JS.InvokeVoidAsync("alert", "Message envoyé avec succès !");
                emailRequest = new MailDTO(); // Reset form
                StateHasChanged();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Erreur : " + (result?.Message ?? "Erreur inconnue"));
                if (!string.IsNullOrEmpty(result?.Error))
                {
                 
                }
            }
        }
        catch (Exception ex)
        {
            //await JS.InvokeVoidAsync("alert", "Erreur technique : " + ex.Message);
        }
    }

    private class MailResponseDTO
    {
        public string Message { get; set; } = "";
        public string? Error { get; set; }
    }
}