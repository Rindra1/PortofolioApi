@page "/addcomptence"
@inherits AddComptenceBase
@using Microsoft.AspNetCore.Components.Forms

<!-- SECTION AJOUT / EDIT EXPERIENCE -->
<section id="add-project" class="fade">
    <h2>@(editing ? "Modifier une expérience" : "Ajouter une expérience")</h2>
    <div class="project-container">
        <!-- Formulaire côté gauche -->
        <form class="project-form" onsubmit="return false;">
                <input type="text" @bind="newExperience.TitreExperience" placeholder="Titre du poste" required>
                <textarea  @bind="newExperience.DetailExperience" placeholder="Description" required></textarea>
                <input type="date" @bind="newExperience.DateDebut" placeholder="Date debut" required>
                <input type="date" @bind="newExperience.DateFin" placeholder="Date de fin">
            <div style="margin-top:0.5rem;">
                <button @onclick="Enregistrer" class="btn-details">@(editing ? "Sauvegarder" : "Enregistrer")</button>
                @if (editing)
                {
                        <button @onclick="AnnulerEdit" class="btn-outline" style="margin-left:0.5rem;">Annuler</button>
                }
            </div>
        </form>
    </div>
</section>

<table class="table">
    <thead>
        <tr>
            <th>Titre</th>
            <th>Description</th>
            <th>Date de début</th>
            <th>Date de fin</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var experience in listeExperience)
        {
            <tr>
                <td>@experience.TitreExperience</td>
                <td>@experience.DetailExperience</td>
                <td>@experience.DateDebut.ToShortDateString()</td>
                <td>@experience.DateFin?.ToShortDateString()</td>
                <td style="white-space:nowrap;">
                    <button class="btn-details" @onclick="() => EditExperience(experience)">Modifier</button>
                    <button class="btn-outline" @onclick="() => SupprimerExperience(experience.IdExperience)" style="margin-left:0.5rem;">Supprimer</button>
                </td>
            </tr>
        }
    </tbody>
</table>

<h1> @message</h1> 