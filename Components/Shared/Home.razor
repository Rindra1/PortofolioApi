<section id="accueil" class="hero-section">
    <div class="container hero">
        <div class="hero-content" data-aos="fade-right">
            <div class="dispo-badge"><span class="green-circle"></span> @Localizer.T("Available")</div>
            <div class="hero-name">@portfolio.Nom <span>@portfolio.Prenom</span></div>
            <div class="hero-title">@Localizer.T("Title")</div>
            <p class="hero-description">@Localizer.T("Resumer") </p>
            <div class="hero-buttons">
                <a href="#projets" class="btn-primary"><i class="fas fa-arrow-right"></i>
                    @Localizer.T("ViewProjects")</a>
                <a href="#contact" class="btn-outline"><i class="fas fa-envelope"></i> @Localizer.T("ContactMe")</a>
            </div>
            <div class="hero-stats">
                <div class="stat-card">
                    <div class="stat-number">5+</div>
                    <div class="stat-label">@Localizer.T("YearsOfExperience")</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">5+</div>
                    <div class="stat-label">@Localizer.T("CompletedProjects")</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">10+</div>
                    <div class="stat-label">Technologies</div>
                </div>
            </div>
            <div class="hero-stack-section">
                <div class="hero-stack-title"><i class="fas fa-layer-group"></i> @Localizer.T("MasteredStack")</div>
                <div class="stack-items">
                    @if (!string.IsNullOrEmpty(portfolio.StackMaitrise))
                    {
                        @foreach (var tech in portfolio.StackMaitrise.Split(','))
                        {
                            <span class="stack-item">@tech</span>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="hero-image-container" data-aos="fade-left">
            <div class="floating-badge floating-badge-1">
                <i class="fab fa-microsoft"></i> Blazor
            </div>
            <div class="floating-badge floating-badge-2">
                <i class="fas fa-code"></i> C# 
            </div>
            <div class="profile-circle">
                <img src="images/@(portfolio.UserImage ?? "chatbot1.png")" alt="@portfolio.Nom @portfolio.Prenom" loading="lazy" width="300" height="300" />
            </div>
        </div>
    </div>
</section>