@page "/home"
@inject HttpClient Http

@* Rendu immédiat même sans données *@
<section id="accueil" class="hero-section">
    <div class="container hero">
        <div class="hero-content">
            <!-- BADGE -->
            <div class="dispo-badge">
                <span class="green-circle"></span> 
                @(Localizer?.T("Available") ?? "Disponible")
            </div>

            <!-- NOM - ÉLÉMENT LCP CRITIQUE -->
            <h1 class="hero-name">
                @(portfolio?.Nom ?? "RAZAFIMANDANONA") 
                <span>@(portfolio?.Prenom ?? "Rindra Niaina")</span>
            </h1>

            <!-- TITRE -->
            <div class="hero-title">@(Localizer?.T("Title") ?? "Développeur Full Stack .NET")</div>

            <!-- DESCRIPTION - ÉLÉMENT LCP PRINCIPAL -->
            <p class="hero-description">
                @(Localizer?.T("Resumer") ?? "Développeur Full Stack .NET avec une solide expérience dans le développement d'applications Web et Desktop.")
            </p>

            <!-- BOUTONS -->
            <div class="hero-buttons">
                <a href="/#projets" @onclick='() => ScrollToSection("projets")' @onclick:preventDefault="true" style="cursor: pointer;" class="btn-primary">
                    <i class="fas fa-arrow-right"></i>
                    @(Localizer?.T("ViewProjects") ?? "Voir mes projets")
                </a>
                <a href="/#contact" @onclick='() => ScrollToSection("contact")' @onclick:preventDefault="true" style="cursor: pointer;" class="btn-outline">
                    <i class="fas fa-envelope"></i> 
                    @(Localizer?.T("ContactMe") ?? "Me contacter")
                </a>
            </div>

            <!-- STATS -->
            <div class="hero-stats">
                <div class="stat-card">
                    <div class="stat-number">5+</div>
                    <div class="stat-label">@(Localizer?.T("YearsOfExperience") ?? "Années d'expérience")</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">@(portfolio?.Projets?.Count ?? 0)+</div>
                    <div class="stat-label">@(Localizer?.T("CompletedProjects") ?? "Projets réalisés")</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">10+</div>
                    <div class="stat-label">Technologies</div>
                </div>
            </div>

            <!-- STACK -->
            <div class="hero-stack-section">
                <div class="hero-stack-title">
                    <i class="fas fa-layer-group"></i> 
                    @(Localizer?.T("MasteredStack") ?? "Stack maîtrisée")
                </div>
                <div class="stack-items">
                    @if (!string.IsNullOrEmpty(portfolio?.StackMaitrise))
                    {
                        @foreach (var tech in portfolio.StackMaitrise.Split(',').Take(8))
                        {
                            <span class="stack-item">@tech.Trim()</span>
                        }
                    }
                    else
                    {
                        <span class="stack-item">C#</span>
                        <span class="stack-item">.NET</span>
                        <span class="stack-item">Blazor</span>
                        <span class="stack-item">ASP.NET Core</span>
                        <span class="stack-item">SQL Server</span>
                        <span class="stack-item">Entity Framework</span>
                        <span class="stack-item">Docker</span>
                    }
                </div>
            </div>
        </div>

        <!-- IMAGE -->
        <div class="hero-image-container">
            <div class="floating-badge floating-badge-1" loading="lazy">
                <i class="fab fa-microsoft"></i> Blazor
            </div>
            <div class="floating-badge floating-badge-2" loading="lazy">
                <i class="fas fa-code"></i> C# 
            </div>
            <div class="profile-circle">
                @{
                    var imagePath = !string.IsNullOrWhiteSpace(portfolio?.UserImage)
                    ? $"images/{portfolio.UserImage}"
                    : "assets/profile.webp";
                }
                <img src="@imagePath.Replace("jpg","webp")"
                     alt="@(portfolio?.Nom ?? "Rindra") @(portfolio?.Prenom ?? "Niaina")"
                     loading="eager"
                     fetchpriority="high"
                     decoding="async"
                     width="300"
                     height="300"
                     importance="high"
                     onerror="this.onerror=null;this.src='/assets/profile.webp';" />
            </div>
        </div>
    </div>
</section>