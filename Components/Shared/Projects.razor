@page "/projects"
<!-- PROJETS -->

<section id="projets">
    <div class="container">
        <h2 class="section-title">@Localizer.T("CompletedProjects")</h2>
        <div class="projets-grid">
            @foreach (var proj in portfolio.Projets)
            {
                var idPart = proj.IdProjet?.ToString() ?? "0";
                var modalId = $"project-{idPart}";
                <div class="card" data-aos="zoom-in">
                    <img src="/images/@(proj.ImageProjet)" alt="@Localizer.T($"Projet.{idPart}.Titre")" loading="lazy"
                         class="project-img" width="320" height="180">
                    <div class="card-content">
                        <h3>@Localizer.T($"Projet.{idPart}.Titre")</h3>
                        <p>@Localizer.T($"Projet.{idPart}.Resumer")</p>
                    </div>
                    <div class="card-actions">
                        <button class="btn-details" onclick="openModal('@modalId')" aria-label="Voir les détails du projet">
                            <i class="fas fa-info-circle"></i> @Localizer.T("Details")
                        </button>
                        @if (!string.IsNullOrEmpty(proj.Lien))
                        {
                            <a href="@proj.Lien" class="btn-github" target="_blank" rel="noopener noreferrer" aria-label="Voir sur GitHub">
                                <i class="fab fa-github"></i> GitHub
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- MODALES PROJETS AVEC CARROUSEL -->
@foreach (var proj in portfolio.Projets)
{
    var idPart = proj.IdProjet?.ToString() ?? "0";
    var modalId = $"project-{idPart}";
    <div id="modal-@modalId" class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title-@modalId">
        <div class="modal-content">
            <span class="modal-close" onclick="closeModal('@modalId')" aria-label="Fermer">&times;</span>
            <h2 id="modal-title-@modalId" class="modal-title">@Localizer.T($"Projet.{idPart}.Titre")</h2>
            <div class="modal-gallery" id="gallery-@modalId">
                <img id="mainImage-@modalId" class="main-image" src="/images/@(proj.ImageProjet)"
                     alt="@Localizer.T($"Projet.{idPart}.Titre")" 
                     width="700" height="300" 
                     loading="eager" fetchpriority="high">
                <div class="thumbnail-container">
                    @if (!string.IsNullOrEmpty(proj.ImageProjet))
                    {
                        <img class="thumbnail" src="/images/@(proj.ImageProjet)" alt="@proj.TitreProjet"
                             data-img="/images/@(proj.ImageProjet)" width="80" height="80">
                    }

                    @if (!string.IsNullOrEmpty(proj.ImageProjet1))
                    {
                        <img class="thumbnail" src="/images/@(proj.ImageProjet1)" alt="@proj.TitreProjet"
                             data-img="/images/@(proj.ImageProjet1)" width="80" height="80">
                    }

                    @if (!string.IsNullOrEmpty(proj.ImageProjet2))
                    {
                        <img class="thumbnail" src="/images/@(proj.ImageProjet2)" alt="@proj.TitreProjet"
                             data-img="/images/@(proj.ImageProjet2)" width="80" height="80">
                    }
                </div>
            </div>
            <p class="modal-description">
                @if (!string.IsNullOrEmpty(proj.DetailProjet))
                {
                    <strong>@Localizer.T("FullDescription") :</strong><br />
                    @(new
            MarkupString(@Localizer.T($"Projet.{idPart}.Detail").Replace("\\n", "<br/>")))
                }
            </p>
            <p class="modal-description">
                @if (!string.IsNullOrEmpty(proj.Fonctionnalite))
                {
                    <strong>@Localizer.T("Features") :</strong><br />
                    @(new
            MarkupString(@Localizer.T($"Projet.{idPart}.Fonctionnalite").Replace("\\n", "<br/>")))
                }
            </p>

            <div class="modal-techs">
                @if (!string.IsNullOrEmpty(proj.Stack))
                {
                    foreach (var tech in proj.Stack.Split(','))
                    {
                        <span class="tech-badge">@tech.Trim()</span>
                    }
                }
            </div>

            <div class="modal-links">
                @if (!string.IsNullOrEmpty(proj.Lien))
                {
                    <a href="@proj.Lien" class="btn-primary" style="padding:0.5rem 1.2rem;" target="_blank"
                           rel="noopener noreferrer" aria-label="Voir sur GitHub">
                        <i class="fab fa-github"></i> @Localizer.T("SeeGithub")
                    </a>
                }
            </div>
        </div>
    </div>
}