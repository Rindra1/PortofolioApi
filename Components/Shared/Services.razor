@page "/services"
<!-- SERVICES -->
<section id="services">
    <div class="container">
        <h2 class="section-title">@Localizer.T("MyServices")</h2>
        <div class="services-grid">
            <div class="service-card" data-aos="flip-left">
                <i class="fas fa-desktop"></i>
                <h3>@Localizer.T("Service.1.Title")</h3>
                <p>@Localizer.T("Service.1.Description")</p>
            </div>

            <div class="service-card" data-aos="flip-left" data-aos-delay="100">
                <i class="fas fa-globe"></i>
                <h3>@Localizer.T("Service.2.Title")</h3>
                <p>@Localizer.T("Service.2.Description")</p>
            </div>
            <div class="service-card" data-aos="flip-left" data-aos-delay="200">
                <i class="fas fa-robot"></i>
                <h3>@Localizer.T("Service.3.Title")</h3>
                <p>@Localizer.T("Service.3.Description")</p>
            </div>

            <div class="service-card" data-aos="flip-left" data-aos-delay="300">
                <i class="fas fa-tools"></i>
                <h3>@Localizer.T("Service.4.Title")</h3>
                <p>@Localizer.T("Service.4.Description")</p>
            </div>
        </div>
    </div>
</section>